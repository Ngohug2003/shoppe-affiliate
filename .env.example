CATALOG_API_BASE_URL=http://api:8000
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLLING_TIMEOUT_SECONDS=30
TELEGRAM_WEBHOOK_ENABLED=false
TELEGRAM_WEBHOOK_SECRET=
